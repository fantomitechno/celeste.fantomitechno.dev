// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Map {
  id            Int       @id @default(autoincrement())
  name          String
  Campaign      Campaign? @relation(fields: [campaignId], references: [id])
  Category      Category? @relation(fields: [categoryId], references: [id])
  campaignId    String?
  categoryId    Int?
  clearedOn     DateTime?
  goldenedOn    DateTime?
  moonBerry     Boolean   @default(false)
  berriesGotten Int       @default(0)
  berries       Int       @default(0)
  goldenPb      Int?
  numberOfRooms Int?
  link          String?
  order         Int       @default(0)
  mapper        String?
  video         String?
  time          Int       @default(0)
  fastestClear  Int?
  lowDeath      Int?
  deaths        Int       @default(0)
}

model Campaign {
  id         String     @id
  name       String
  maps       Map[]
  categories Category[]
  link       String?
  mapper     String?
}

model Category {
  id         Int      @id @default(autoincrement())
  name       String
  color      String   @default("#ffffff")
  Campaign   Campaign @relation(fields: [campaignId], references: [id])
  campaignId String
  maps       Map[]
  order      Int      @default(0)
}
