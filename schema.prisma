generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Map {
  // Metadata
  id         Int       @id @default(autoincrement())
  name       String
  Campaign   Campaign? @relation(fields: [campaignId], references: [id])
  Category   Category? @relation(fields: [categoryId], references: [id])
  campaignId String?
  categoryId Int?
  link       String?
  order      Int       @default(0)
  mapper     String?
  video      String?
  mapType    MapType?

  // Date informations
  clearedOn   DateTime?
  deathlessOn DateTime?

  // Collectibles infos
  containsMoonBerry Boolean   @default(false)
  containsCassette  Boolean   @default(false)
  containsHeart     Boolean   @default(true)
  heartType         HeartType @default(BLUE)
  containsBerries   Int       @default(0)

  // Collected infos
  collectedMoonBerry Boolean @default(false)
  collectedberries   Int     @default(0)
  collectedCassette  Boolean @default(false)
  collectedHeart     Boolean @default(false)

  // Deathless informations
  deathlessType DeathlessBerry @default(GOLDEN)
  deathlessPb   Int?
  numberOfRooms Int?

  // Stats
  time         Int  @default(0)
  deaths       Int  @default(0)
  fastestClear Int?
  lowDeaths    Int?

  // Customs textures
  customGhostHeart          String?
  customHeart               String?
  customGhostDeathlessBerry String?
  customDeathlessBerry      String?
  customGhostBerry          String?
  customBerry               String?
  customGhostMoonBerry      String?
  customMoonBerry           String?
  customHeartSide           String?
}

enum DeathlessBerry {
  GOLDEN
  SILVER
  PLATINUM
}

enum HeartType {
  BLUE
  RED
  YELLOW
  ORANGE
  PURPLE
  COLLAB_BLUE
  COLLAB_RED
  COLLAB_YELLOW
  COLLAB_ORANGE
  COLLAB_PURPLE
}

enum MapType {
  GREEN
  YELLOW
  RED
  CRACKED
  HEARTSIDE
}

model Campaign {
  // Metadata
  id     String  @id
  name   String
  link   String?
  mapper String?

  // Maps infos
  maps       Map[]
  categories Category[]
}

model Category {
  // Metadata
  id         Int      @id @default(autoincrement())
  name       String
  color      String   @default("#ffffff")
  Campaign   Campaign @relation(fields: [campaignId], references: [id])
  campaignId String
  maps       Map[]
  order      Int      @default(0)

  // Rainbow
  containsRainbow Boolean @default(false)
}
